---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="会社案内 | Sunrise Estate">
  <div class="py-12 md:py-20 max-w-4xl mx-auto px-6 md:grid-cols-3">
    <h1 class="text-3xl md:text-4xl font-bold text-slate-800 mb-12 text-center">会社案内</h1>

    <!-- 会社概要テーブル -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-slate-800 mb-6 border-l-4 border-blue-600 pl-4">会社概要</h2>
      <div class="overflow-hidden rounded-xl border border-slate-200">
        <table class="w-full text-left">
          <tbody>
            {[
              { label: "会社名", value: "Sunrise Estate株式会社" },
              { label: "所在地", value: "東京都○○区○○1-2-3" },
              { label: "設立", value: "2015年4月" },
              { label: "代表者", value: "山田 太郎" },
              { label: "事業内容", value: "売買仲介・賃貸仲介・賃貸管理・不動産コンサルティング" },
            ].map((row) => (
              <tr class="border-b border-slate-100 last:border-b-0">
                <th class="bg-slate-50 p-4 font-semibold text-slate-700 w-1/3 ">{row.label}</th>
                <td class="p-4 text-slate-600">{row.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 企業理念 -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-slate-800 mb-6 border-l-4 border-blue-600 pl-4">企業理念</h2>
      <div class="bg-blue-50 p-8 rounded-xl">
        <ul class="space-y-4 text-slate-700">
          <li class="flex items-start gap-3">
            <span class="text-blue-600 font-bold">●</span>地域に根ざした住まい探しをサポートします。
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-600 font-bold">●</span>誠実で分かりやすいご提案を心掛けます。
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-600 font-bold">●</span>お客様との信頼関係を大切にします。
          </li>
        </ul>
      </div>
    </section>

    <!-- 代表メッセージ -->
    <section>
      <h2 class="text-2xl font-bold text-slate-800 mb-6 border-l-4 border-blue-600 pl-4">代表メッセージ</h2>
      <div class="space-y-6 text-slate-600 leading-relaxed">
        <p>
          Sunrise Estateは、地域の皆さまに安心してご相談いただける不動産会社を目指しています。
        </p>
        <p>
          お客様一人ひとりのライフスタイルに合わせた住まい探しを、スタッフ一同、誠心誠意サポートいたします。
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
