---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const latestNews = (await getCollection("news"))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const company = {
  name: "Sunrise Estate 不動産",
  slogan: "地域に寄り添う不動産会社",
};
---

<BaseLayout title="Sunrise Estate" description="地域に寄り添う不動産会社。売買・賃貸・物件管理まで幅広くサポートします。">
  <!-- ヒーローセクション -->
  <section class="py-16 md:py-24 text-center md:px-10">
    <h1 class="text-4xl font-bold text-slate-800 mb-6 md:text-5xl">
      {company.name}
    </h1>
    <h2 class="text-xl md:text-2xl text-slate-600 mb-8">{company.slogan}</h2>
    <p class="text-lg text-slate-500 max-w-2xl mx-auto mb-10 md:text-lg">
      私たちは売買・賃貸・管理まで、お客様の暮らしをトータルサポートいたします。地域に根ざした信頼の実績で、あなたの理想の住まい探しをお手伝いします。
    </p>
    <a
      href="/contact"
      class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-700 transition shadow-lg"
    >
      無料相談はこちら
    </a>
  </section>

  <!-- お知らせセクション -->
  <section class="bg-slate-50 rounded-3xl p-8 md:p-12">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-2xl font-bold text-slate-800">最新のお知らせ</h2>
      <a href="/news" class="text-blue-600 hover:underline font-medium"
        >一覧を見る &rarr;</a
      >
    </div>

    <ul class="grid gap-4">
      {
        latestNews.map((item) => (
          <li>
            <a
              href={`/news/${item.id}`}
              class="block bg-white p-6 rounded-xl border border-slate-200 hover:border-blue-300 hover:shadow-md transition-all"
            >
              <div class="text-sm text-slate-400 mb-1">
                {item.data.pubDate.toLocaleDateString("ja-JP")}
              </div>
              <div class="font-bold text-slate-800">{item.data.title}</div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
