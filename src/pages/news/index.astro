---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const news = (await getCollection("news")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout title="お知らせ | Sunrise Estate">
  <div class="py-12 md:py-20 max-w-4xl mx-auto px-6">
    <h1 class="text-3xl md:text-4xl font-bold text-slate-800 mb-12 text-center">お知らせ</h1>
    
    <section>
      <ul class="space-y-6">
        {
          news.map((item) => (
            <li class="border-b border-slate-200 pb-6 last:border-0">
              <article>
                <div class="flex items-center gap-4 mb-2">
                  <time class="text-sm text-slate-500 bg-slate-100 px-3 py-1 rounded-full">
                    {item.data.pubDate.toLocaleDateString("ja-JP", {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                </div>
                <h2 class="text-xl font-bold text-slate-800 mb-2 hover:text-blue-600 transition-colors">
                  <a href={`/news/${item.id}`}>{item.data.title}</a>
                </h2>
                <p class="text-slate-600 line-clamp-2">{item.data.description}</p>
                <a href={`/news/${item.id}`} class="inline-block mt-3 text-blue-600 font-medium hover:underline">
                  続きを読む &rarr;
                </a>
              </article>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>