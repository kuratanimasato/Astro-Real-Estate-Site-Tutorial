---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogList } from "../../library/microcms";
import { Image } from 'astro:assets';
const { thumbnail } = Astro.props;
const { contents: blogs } = await getBlogList();
---

<BaseLayout title="ブログ記事一覧">
  <h1 class="text-3xl font-extrabold text-center mb-12">ブログ記事</h1>

  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {blogs.map((blog) => (
      <article class="group flex flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition hover:shadow-xl">
        <a href={`/blog/${blog.id}`} class="block aspect-video overflow-hidden">
          <img
            src={blog.eyecatch.url}
            alt={blog.title}
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
          />
        </a>

        <div class="flex flex-1 flex-col p-6">
          <div class="mb-3">
            <span class="inline-block rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-600">
              {blog.category.name}
            </span>
          </div>

          <h2 class="mb-3 text-xl font-bold leading-tight text-gray-900 group-hover:text-blue-600">
            <a href={`/blog/${blog.id}`}>{blog.title}</a>
          </h2>

          <p class="mb-4 flex-1 text-sm text-gray-600 line-clamp-3">
            {blog.description}
          </p>

          <time datetime={blog.publishedAt} class="text-xs text-gray-400">
            {new Date(blog.publishedAt).toLocaleDateString("ja-JP", {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
