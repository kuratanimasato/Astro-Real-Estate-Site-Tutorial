---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBlogList } from "@/library/microcms";
import { Image } from 'astro:assets';
const { thumbnail } = Astro.props;
import { GetStaticPaths } from "astro";
import Pagination from "@/components/Pagination.astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const { contents: blogs } = await getBlogList({
    orders: "-publishedAt",

  });
  return paginate(blogs, {
     pageSize: 5,
   });
};
const { page } = Astro.props;
---
<BaseLayout title="ブログ記事一覧">
  <div class="mx-auto max-w-7xl px-4 py-12">
    <h1 class="mb-12 text-center text-4xl font-bold">
      ブログ記事一覧
    </h1>

    <!-- 記事一覧 -->
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {page.data.map((blog) => (
        <article class="group overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <a href={`/blog/${blog.id}`}>
            <img
              src={blog.eyecatch.url}
              alt={blog.title}
              class="h-56 w-full object-cover transition duration-500 group-hover:scale-105"
            />

            <div class="p-6">
              <span class="inline-block rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
                {blog.category.name}
              </span>

              <h2 class="mt-4 text-xl font-bold text-gray-900 group-hover:text-blue-600">
                {blog.title}
              </h2>

              <p class="mt-3 line-clamp-3 text-gray-600">
                {blog.description}
              </p>

              <time
                datetime={blog.publishedAt}
                class="mt-5 block text-sm text-gray-400"
              >
                {new Date(blog.publishedAt).toLocaleDateString("ja-JP")}
              </time>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- ページネーション -->
    <Pagination page={page} />
  </div>
</BaseLayout>
