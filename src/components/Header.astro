<header class="border-b border-slate-200 bg-white shadow-sm sticky top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="text-2xl font-bold text-blue-600 flex items-center gap-2">
      🏠 Sunrise Estate
    </a>

    <button id="menu-toggle" class="md:hidden p-2 text-slate-700">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
      </svg>
    </button>

    <nav id="menu" class="hidden md:flex flex-col md:flex-row absolute md:static top-full left-0 w-full md:w-auto bg-white border-b md:border-none p-6 md:p-0 gap-6 text-slate-700 font-medium">
      <a href="/" class="hover:text-blue-600 transition-colors">ホーム</a>
      <a href="/company" class="hover:text-blue-600 transition-colors">会社案内</a>
      <a href="/service" class="hover:text-blue-600 transition-colors">サービス</a>
      <a href="/news" class="hover:text-blue-600 transition-colors">お知らせ</a>
      <a href="/blog" class="hover:text-blue-600 transition-colors">ブログ</a>
      <a href="/campaign" class="hover:text-blue-600 transition-colors">キャンペーン</a>
      <a href="/contact" class="bg-blue-600 text-white px-5 py-2 rounded-full hover:bg-blue-700 transition-all text-center">
        お問い合わせ
      </a>
    </nav>
  </div>
</header>

<script>
  // ハンバーガーメニューの開閉スクリプト
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('menu');

  btn.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    menu.classList.toggle('flex');
  });
</script>
